# =============================================================================
# TaxIA - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values

# === Azure AI Foundry (LLM) ===
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# === Azure Document Intelligence (PDF Extraction) ===
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-document-intelligence-key

# === Turso Database ===
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# === Upstash Redis ===
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# === JWT Authentication ===
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Paths and Directories ===
PDF_DIR=./data
PARQUET_PATH=./data/aeat_corpus.parquet
META_PATH=./data/aeat_meta.parquet
INDEX_PATH=./data/aeat_faiss.index
CACHE_DIR=./cache

# === AI Models (Embeddings) ===
EMBEDDING_MODEL=mixedbread-ai/mxbai-embed-large-v1
RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# === RAG Configuration ===
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
RETRIEVAL_K=6
RERANK_K=3

# === Generation Settings ===
TEMPERATURE=0.2
MAX_TOKENS=1200

# === Guardrails ===
ENABLE_GUARDRAILS=true
TOXICITY_THRESHOLD=0.8
HALLUCINATION_THRESHOLD=0.85

# === Valid/Invalid Topics ===
VALID_TOPICS=fiscalidad española,AEAT,impuestos,tributación,Hacienda,declaración,IVA,IRPF,Sociedades,Patrimonio,modelo,formulario,deducción
INVALID_TOPICS=inversiones bursátiles,préstamos,seguros de vida,criptomonedas trading,forex,opciones financieras
COMPETITORS=Tax Advisor,Gestoría Martinez,Asesor Fiscal López,TurboTax,H&R Block,TaxAct,FreeTaxUSA

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=10

# === Logging ===
LOG_LEVEL=INFO

# === Admin ===
ADMIN_API_KEY=your-secure-admin-key-here
