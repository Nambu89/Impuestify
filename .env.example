# ================================================================================
# TaxIA - Configuration Template
# ================================================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control!
# ================================================================================

# ================================================================================
# 🤖 OpenAI API (Primary LLM for Tax Queries)
# ================================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini

# Optional: Azure OpenAI Fallback
# AZURE_OPENAI_API_KEY=your_azure_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ================================================================================
# 🛡️ GROQ API (AI Security Layer)
# ================================================================================
# Required for: Llama Guard, Prompt Injection Detection, Complexity Router
# Get your API key at: https://console.groq.com/keys
# Free tier: 14,400 requests/day
GROQ_API_KEY=your_groq_api_key_here

# Optional: Override default GROQ models (use defaults if not specified)
# GROQ_MODEL=meta-llama/llama-guard-4-12b
# GROQ_MODEL_ROUTER=llama-3.1-8b-instant
# GROQ_MODEL_PROMPT_GUARD=meta-llama/llama-prompt-guard-2-86m
# GROQ_MODEL_SAFETY=meta-llama/llama-guard-4-12b

# Enable/Disable Content Moderation (default: true)
ENABLE_CONTENT_MODERATION=true

# ================================================================================
# 🗄️ Turso Database (SQLite in the Cloud)
# ================================================================================
# Required for: RAG embeddings, user data, conversations
# Get started at: https://turso.tech/
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# ================================================================================
# 📦 Upstash Redis (Caching Layer)
# ================================================================================
# Optional but recommended for response caching
# Get started at: https://upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ================================================================================
# 🧠 Upstash Vector (Semantic Cache)
# ================================================================================
# Optional: Semantic similarity-based caching
UPSTASH_VECTOR_REST_URL=https://your-vector.upstash.io
UPSTASH_VECTOR_REST_TOKEN=your_vector_token

# Enable/Disable semantic cache (default: true)
ENABLE_SEMANTIC_CACHE=true
SEMANTIC_CACHE_THRESHOLD=0.93

# ================================================================================
# 📄 Azure Document Intelligence (PDF Parsing - Optional)
# ================================================================================
# Optional: For advanced PDF document analysis
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# DOCUMENT_INTELLIGENCE_API_KEY=your_document_intelligence_key

# ================================================================================
# 🔒 JWT Authentication
# ================================================================================
# CRITICAL: Change this in production!
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ================================================================================
# 🛡️ Security Settings
# ================================================================================
# Guardrails
ENABLE_GUARDRAILS=true
TOXICITY_THRESHOLD=0.8
HALLUCINATION_THRESHOLD=0.85

# Rate Limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=10

# ================================================================================
# 📁 Data Paths (usually defaults are fine)
# ================================================================================
# BASE_DIR=./data
# PDF_DIR=./data
# INDEX_DIR=./data
# CACHE_DIR=./cache
# PARQUET_PATH=./data/aeat_corpus.parquet
# META_PATH=./data/aeat_meta.parquet
# INDEX_PATH=./data/aeat_faiss.index

# ================================================================================
# 🧠 Embedding Models (defaults usually work well)
# ================================================================================
# EMBEDDING_MODEL=mixedbread-ai/mxbai-embed-large-v1
# RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ================================================================================
# ⚙️ LLM Parameters
# ================================================================================
# TEMPERATURE=1.0
# MAX_TOKENS=1200

# ================================================================================
# 🔍 RAG Parameters
# ================================================================================
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=150
# RETRIEVAL_K=6
# RERANK_K=3

# ================================================================================
# 📋 Domain Configuration
# ================================================================================
# Valid topics (comma-separated)
# VALID_TOPICS=fiscalidad española,AEAT,impuestos,tributación,Hacienda,declaración,IVA,IRPF,Sociedades,Patrimonio,modelo,formulario,deducción

# Invalid topics to reject
# INVALID_TOPICS=inversiones bursátiles,préstamos,seguros de vida,criptomonedas trading,forex,opciones financieras

# Competitors to not promote
# COMPETITORS=Tax Advisor,Gestoría Martinez,Asesor Fiscal López,TurboTax,H&R Block,TaxAct,FreeTaxUSA

# ================================================================================
# 📊 Logging
# ================================================================================
LOG_LEVEL=INFO

# ================================================================================
# 🔑 Admin Access
# ================================================================================
# CRITICAL: Change this in production!
ADMIN_API_KEY=your-secure-admin-key-change-in-production

# ================================================================================
# 🌐 CORS (Frontend domains allowed to call the API)
# ================================================================================
# For development: use "*" to allow all origins
# For production: specify exact domains (comma-separated)
ALLOWED_ORIGINS=*
# Production example:
# ALLOWED_ORIGINS=https://taxia.com,https://www.taxia.com

# ================================================================================
# 📦 Environment
# ================================================================================
# Environment indicator (development, staging, production)
# ENVIRONMENT=development
